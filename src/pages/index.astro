---
const stops = [
  {
    time: '16:00',
    kicker: 'Stop 01',
    kickerIt: 'Tappa 01',
    title: 'THE PARKING+ opens the portal',
    titleIt: 'THE PARKING+ apre il portale',
    href: 'https://www.schallfenster.art/parking',
    text: 'Olaf arrives at Schallfenster’s secret Zürich location. Wristband acquired. Civilian identity begins to dissolve.',
    textIt: 'Olaf arriva nella location segreta di Schallfenster a Zurigo. Braccialetto ottenuto. L’identità civile inizia a dissolversi.',
    meta: 'Schallfenster · Zürich · secret location',
    metaIt: 'Schallfenster · Zurigo · location segreta',
    badge: 'confirmed',
    badgeIt: 'confermato',
    calendarHref: '/olaf-parking-plus.ics'
  },
  {
    time: '16:00–18:00',
    kicker: 'Set 01',
    kickerIt: 'Set 01',
    title: 'GEM',
    titleIt: 'GEM',
    text: 'Opening transmission. Soft launch into the bass dimension.',
    textIt: 'Trasmissione di apertura. Lancio morbido nella dimensione dei bassi.',
    meta: 'Parking session',
    metaIt: 'sessione Parking',
    badge: 'warm-up',
    badgeIt: 'riscaldamento'
  },
  {
    time: '18:00–20:00',
    kicker: 'Set 02',
    kickerIt: 'Set 02',
    title: 'DJ Mashallah',
    titleIt: 'DJ Mashallah',
    text: 'Signal strength increases. Olaf is now best tracked by rhythm, not GPS.',
    textIt: 'Il segnale aumenta. Ora Olaf si traccia meglio col ritmo che col GPS.',
    meta: 'Parking session',
    metaIt: 'sessione Parking',
    badge: 'rising',
    badgeIt: 'in salita'
  },
  {
    time: '20:00–22:00',
    kicker: 'Set 03',
    kickerIt: 'Set 03',
    title: 'Carla Durisch',
    titleIt: 'Carla Durisch',
    text: 'Prime-time slot. “One more track” becomes a legally binding emotional contract.',
    textIt: 'Fascia prime-time. “Ancora una traccia” diventa un contratto emotivo legalmente vincolante.',
    meta: 'Crosstown Rebels',
    metaIt: 'Crosstown Rebels',
    badge: 'peak',
    badgeIt: 'picco'
  },
  {
    time: '23:00',
    kicker: 'Stop 02',
    kickerIt: 'Tappa 02',
    title: 'Contrabbasso migration',
    titleIt: 'Migrazione verso Contrabbasso',
    text: 'Olaf leaves THE PARKING+ and continues to Contrabbasso for further low-frequency fieldwork.',
    textIt: 'Olaf lascia THE PARKING+ e continua verso Contrabbasso per ulteriore ricerca sul campo a bassa frequenza.',
    meta: 'second destination',
    metaIt: 'seconda destinazione',
    badge: 'next',
    badgeIt: 'prossima',
    calendarHref: '/olaf-contrabbasso.ics'
  },
  {
    time: 'late',
    kicker: 'Protocol',
    kickerIt: 'Protocollo',
    title: 'Scientifically unavailable',
    titleIt: 'Scientificamente non disponibile',
    text: 'If discovered: offer water. If dancing: do not disturb. If philosophical: deploy fries.',
    textIt: 'Se avvistato: offrire acqua. Se balla: non disturbare. Se diventa filosofico: schierare patatine.',
    meta: 'status unknown, vibes loud',
    metaIt: 'stato ignoto, vibrazioni forti',
    badge: 'olaf mode',
    badgeIt: 'modalità olaf'
  }
];

const stats = [
  ['02.05.26', 'Saturday file', 'file del sabato'],
  ['16:00', 'first signal', 'primo segnale'],
  ['23:00', 'bass migration', 'migrazione bassi'],
  ['∞', 'Olaf lore', 'mitologia Olaf']
];

const weather = {
  location: 'Zürich',
  now: 'sunny · clear',
  nowIt: 'sole · sereno',
  feels: 'feels like pure optimism',
  feelsIt: 'percepito: puro ottimismo',
  wind: '7 km/h wind',
  windIt: 'vento 7 km/h',
  humidity: '56% humidity',
  humidityIt: 'umidità 56%',
  outlook: [
    ['15:00', 'sun', 'sunny', 'soleggiato', '0% rain drama', '0% dramma pioggia'],
    ['18:00', 'sun', 'still sunny', 'ancora sole', 'terrace approved', 'terrazza approvata'],
    ['21:00', 'clear', 'clear sky', 'cielo sereno', 'Olaf-safe', 'sicuro per Olaf']
  ],
  advice: 'Only sun. Sunglasses recommended. Umbrella banned from the itinerary for spreading misinformation.',
  adviceIt: 'Solo sole. Occhiali consigliati. Ombrello bandito dall’itinerario per diffusione di disinformazione.'
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>onlyplans.lol — Olaf’s Saturday</title>
    <meta name="description" content="Olaf’s actual Saturday itinerary: THE PARKING+ by Schallfenster, then Contrabbasso." />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <div class="orb orb-one" aria-hidden="true"></div>
    <div class="orb orb-two" aria-hidden="true"></div>

    <a class="skip-link" href="#timeline" data-i18n="skip">Skip to schedule</a>
    <main class="site-shell">
      <nav class="topbar" aria-label="Top navigation">
        <a class="brand" href="/" aria-label="onlyplans home">
          <span class="brand-mark">☃️</span>
          <span>onlyplans</span>
        </a>
        <div class="nav-actions">
          <div class="nav-status"><span></span> <span data-i18n="navStatus">Olaf live-ish tracker</span></div>
          <div class="language-toggle" aria-label="Language switcher">
            <button type="button" class="active" data-lang-button="en" aria-pressed="true">EN</button>
            <button type="button" data-lang-button="it" aria-pressed="false">IT</button>
          </div>
        </div>
      </nav>

      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="eyebrow" data-i18n="eyebrow">Zürich · Saturday · highly unofficial operations desk</p>
          <h1 id="page-title"><span data-i18n="heroTitlePrefix">Olaf has</span> <em data-i18n="heroTitleEm">plans</em>.</h1>
          <p class="lede" data-i18n-html="lede">Tonight’s itinerary is no longer theoretical: first <a href="https://www.schallfenster.art/parking" target="_blank" rel="noopener">THE PARKING+ by Schallfenster</a>, then a dignified little bass pilgrimage to <strong>Contrabbasso</strong>.</p>

          <div class="cta-row">
            <a class="primary-cta" href="#timeline" data-i18n="primaryCta">View the route</a>
            <a class="ghost-cta" href="https://www.schallfenster.art/parking" target="_blank" rel="noopener">Schallfenster ↗</a>
            <a class="calendar-cta" href="/olaf-saturday.ics" download data-i18n="calendarCta">Add all to calendar</a>
          </div>

          <div class="stats" aria-label="Plan summary">
            {stats.map(([value, label, labelIt]) => (
              <div class="stat"><strong>{value}</strong><span data-en={label} data-it={labelIt}>{label}</span></div>
            ))}
          </div>
        </div>

        <aside class="mission-card" aria-label="Olaf mission card">
          <div class="card-label" data-i18n="currentMission">CURRENT MISSION</div>
          <div class="route-map">
            <div class="route-node active"><span>01</span><strong>THE PARKING+</strong><small>Schallfenster</small></div>
            <div class="route-line"></div>
            <div class="route-node"><span>02</span><strong>Contrabbasso</strong><small data-i18n="secondAct">second act</small></div>
          </div>
          <div class="weather-widget" aria-label="Zürich weather snapshot">
            <div>
              <span class="weather-kicker"><span data-i18n="weatherNow">weather now</span> · {weather.location}</span>
              <strong data-en={weather.now} data-it={weather.nowIt}>{weather.now}</strong>
              <p><span data-en={weather.feels} data-it={weather.feelsIt}>{weather.feels}</span> · <span data-en={weather.wind} data-it={weather.windIt}>{weather.wind}</span> · <span data-en={weather.humidity} data-it={weather.humidityIt}>{weather.humidity}</span></p>
            </div>
            <div class="weather-icon" aria-hidden="true">☀️</div>
          </div>
          <div class="olaf-chip" data-i18n="olafStatus">Status: beautifully over-scheduled</div>
        </aside>
      </section>

      <section class="timeline-section" id="timeline" aria-labelledby="timeline-title">
        <div class="section-heading">
          <p data-i18n="actualSchedule">Actual schedule</p>
          <h2 id="timeline-title" data-i18n="runSheet">The Olaf Saturday run sheet</h2>
        </div>

        <div class="timeline">
          {stops.map((stop) => (
            <article class="timeline-card">
              <div class="time-block"><span data-en={stop.kicker} data-it={stop.kickerIt}>{stop.kicker}</span><strong>{stop.time}</strong></div>
              <div class="timeline-body">
                <h3>{stop.href ? <a href={stop.href} target="_blank" rel="noopener" data-en={stop.title} data-it={stop.titleIt}>{stop.title}</a> : <span data-en={stop.title} data-it={stop.titleIt}>{stop.title}</span>}</h3>
                <p data-en={stop.text} data-it={stop.textIt}>{stop.text}</p>
                <small data-en={stop.meta} data-it={stop.metaIt}>{stop.meta}</small>
              </div>
              <div class="timeline-actions">
                <div class="badge" data-en={stop.badge} data-it={stop.badgeIt}>{stop.badge}</div>
                {stop.calendarHref && <a class="mini-calendar" href={stop.calendarHref} download data-i18n="addStop">Add</a>}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="weather-section" aria-labelledby="weather-title">
        <div class="section-heading compact">
          <p data-i18n="weatherIntel">Weather intelligence</p>
          <h2 id="weather-title" data-i18n="weatherTitle">Can Olaf survive outside?</h2>
        </div>
        <div class="weather-panel">
          <div class="weather-main">
            <span>☀️</span>
            <div>
              <strong>{weather.location}: <span data-en={weather.now} data-it={weather.nowIt}>{weather.now}</span></strong>
              <p data-en={weather.advice} data-it={weather.adviceIt}>{weather.advice}</p>
            </div>
          </div>
          <div class="weather-slots">
            {weather.outlook.map(([time, temp, condition, conditionIt, rain, rainIt]) => (
              <div class="weather-slot">
                <span>{time}</span>
                <strong>{temp}</strong>
                <p data-en={condition} data-it={conditionIt}>{condition}</p>
                <small data-en={rain} data-it={rainIt}>{rain}</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="cards-grid" aria-label="Plan notes">
        <div class="note-card big">
          <span>🅿️</span>
          <h3 data-i18n="note1Title">Parking first</h3>
          <p data-i18n="note1Text">Schallfenster’s 12-hour session is the launchpad: secret location, presale-only, wristband-powered.</p>
        </div>
        <div class="note-card">
          <span>🎻</span>
          <h3 data-i18n="note2Title">Contrabbasso next</h3>
          <p data-i18n="note2Text">The second destination has class, bass, and suspiciously late-night timing.</p>
        </div>
        <div class="note-card">
          <span>🛰️</span>
          <h3 data-i18n="note3Title">Tracking method</h3>
          <p data-i18n="note3Text">Approximate. Vibe-based. Legally distinct from surveillance.</p>
        </div>
        <div class="note-card wild-card">
          <span>🌀</span>
          <h3 data-i18n="note4Title">Side quest</h3>
          <p data-i18n="note4Text">Olaf is also looking for a crazy girl — ideally the fun kind, not the police-report kind.</p>
        </div>
      </section>

      <footer>
        <span>onlyplans.lol</span>
        <span data-i18n="footer">Built with Astro. Powered by Olaf’s inability to stay home.</span>
      </footer>
    </main>

    <script>
      const translations = {
        en: {
          skip: 'Skip to schedule',
          navStatus: 'Olaf live-ish tracker',
          eyebrow: 'Zürich · Saturday · highly unofficial operations desk',
          heroTitlePrefix: 'Olaf has',
          heroTitleEm: 'plans',
          lede: 'Tonight’s itinerary is no longer theoretical: first <a href="https://www.schallfenster.art/parking" target="_blank" rel="noopener">THE PARKING+ by Schallfenster</a>, then a dignified little bass pilgrimage to <strong>Contrabbasso</strong>.',
          primaryCta: 'View the route',
          calendarCta: 'Add all to calendar',
          addStop: 'Add',
          currentMission: 'CURRENT MISSION',
          secondAct: 'second act',
          weatherNow: 'weather now',
          olafStatus: 'Status: beautifully over-scheduled',
          actualSchedule: 'Actual schedule',
          runSheet: 'The Olaf Saturday run sheet',
          weatherIntel: 'Weather intelligence',
          weatherTitle: 'Can Olaf survive outside?',
          note1Title: 'Parking first',
          note1Text: 'Schallfenster’s 12-hour session is the launchpad: secret location, presale-only, wristband-powered.',
          note2Title: 'Contrabbasso next',
          note2Text: 'The second destination has class, bass, and suspiciously late-night timing.',
          note3Title: 'Tracking method',
          note3Text: 'Approximate. Vibe-based. Legally distinct from surveillance.',
          note4Title: 'Side quest',
          note4Text: 'Olaf is also looking for a crazy girl — ideally the fun kind, not the police-report kind.',
          footer: 'Built with Astro. Powered by Olaf’s inability to stay home.'
        },
        it: {
          skip: 'Vai al programma',
          navStatus: 'Tracker quasi-live di Olaf',
          eyebrow: 'Zurigo · sabato · desk operativo molto non ufficiale',
          heroTitlePrefix: 'Olaf ha',
          heroTitleEm: 'piani',
          lede: 'L’itinerario di stasera non è più teorico: prima <a href="https://www.schallfenster.art/parking" target="_blank" rel="noopener">THE PARKING+ di Schallfenster</a>, poi un piccolo pellegrinaggio dignitoso verso <strong>Contrabbasso</strong>.',
          primaryCta: 'Vedi il percorso',
          calendarCta: 'Aggiungi tutto al calendario',
          addStop: 'Aggiungi',
          currentMission: 'MISSIONE ATTUALE',
          secondAct: 'secondo atto',
          weatherNow: 'meteo ora',
          olafStatus: 'Stato: magnificamente sovra-programmato',
          actualSchedule: 'Programma reale',
          runSheet: 'La scaletta del sabato di Olaf',
          weatherIntel: 'Intelligence meteo',
          weatherTitle: 'Olaf può sopravvivere fuori?',
          note1Title: 'Prima Parking',
          note1Text: 'La sessione di 12 ore di Schallfenster è la rampa di lancio: location segreta, solo prevendita, alimentata da braccialetto.',
          note2Title: 'Poi Contrabbasso',
          note2Text: 'La seconda destinazione ha classe, bassi e un tempismo sospettosamente notturno.',
          note3Title: 'Metodo di tracciamento',
          note3Text: 'Approssimativo. Basato sulle vibrazioni. Legalmente distinto dalla sorveglianza.',
          note4Title: 'Missione secondaria',
          note4Text: 'Olaf cerca anche una ragazza fuori di testa — idealmente in modo divertente, non da verbale di polizia.',
          footer: 'Costruito con Astro. Alimentato dall’incapacità di Olaf di restare a casa.'
        }
      };

      const setLanguage = (lang) => {
        const dictionary = translations[lang] || translations.en;
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach((node) => {
          const key = node.dataset.i18n;
          if (dictionary[key]) node.textContent = dictionary[key];
        });
        document.querySelectorAll('[data-i18n-html]').forEach((node) => {
          const key = node.dataset.i18nHtml;
          if (dictionary[key]) node.innerHTML = dictionary[key];
        });
        document.querySelectorAll('[data-en][data-it]').forEach((node) => {
          node.textContent = node.dataset[lang] || node.dataset.en;
        });
        document.querySelectorAll('[data-lang-button]').forEach((button) => {
          const active = button.dataset.langButton === lang;
          button.classList.toggle('active', active);
          button.setAttribute('aria-pressed', String(active));
        });
        localStorage.setItem('onlyplans-language', lang);
      };

      const initialLanguage = localStorage.getItem('onlyplans-language') || 'en';
      setLanguage(initialLanguage);
      document.querySelectorAll('[data-lang-button]').forEach((button) => {
        button.addEventListener('click', () => setLanguage(button.dataset.langButton));
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;

    /* Primitive + semantic tokens, per the web-design skill */
    --ink: #f8fafc;
    --muted: #a7b0c0;
    --subtle: rgba(248, 250, 252, .72);
    --surface-0: #070a12;
    --surface-1: rgba(12, 18, 32, .72);
    --surface-2: rgba(19, 27, 46, .9);
    --line: rgba(255, 255, 255, .13);
    --hot: #ff4fd8;
    --blue: #66e3ff;
    --lime: #d8ff6f;
    --amber: #ffb86b;

    --space-2: .5rem;
    --space-3: .75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;
    --space-16: 4rem;

    --radius-card: 2.25rem;
    --radius-panel: 1.75rem;
    --radius-pill: 999px;
    --shadow: 0 32px 90px rgba(0, 0, 0, .42);
    --shadow-soft: 0 18px 42px rgba(0, 0, 0, .28);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at 15% 12%, rgba(102, 227, 255, .28), transparent 30rem),
      radial-gradient(circle at 82% 6%, rgba(255, 79, 216, .26), transparent 28rem),
      radial-gradient(circle at 55% 100%, rgba(216, 255, 111, .14), transparent 34rem),
      linear-gradient(135deg, #070a12 0%, #101827 48%, #070a12 100%);
    overflow-x: hidden;
  }

  a { color: inherit; }

  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: .09;
    z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 260 260' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .orb {
    position: fixed;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(8px);
    z-index: 0;
  }

  .orb-one { width: 18rem; height: 18rem; left: -6rem; bottom: 10%; background: rgba(255, 184, 107, .18); }
  .orb-two { width: 24rem; height: 24rem; right: -8rem; bottom: -8rem; background: rgba(102, 227, 255, .16); }

  .site-shell {
    position: relative;
    z-index: 1;
    width: min(1160px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 44px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    font-weight: 950;
    letter-spacing: -.05em;
    font-size: clamp(1.25rem, 2vw, 1.7rem);
  }

  .brand-mark {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 255, 255, .08);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.18), 0 16px 42px rgba(0,0,0,.28);
    animation: float 4.5s ease-in-out infinite;
  }


  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  .language-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 5px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, .06);
    backdrop-filter: blur(18px);
  }

  .language-toggle button {
    min-width: 44px;
    min-height: 36px;
    border: 0;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: .82rem;
    font-weight: 950;
    cursor: pointer;
  }

  .language-toggle button.active {
    background: var(--lime);
    color: #07101d;
  }


  .nav-status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, .06);
    color: var(--subtle);
    font-weight: 800;
    font-size: .9rem;
    backdrop-filter: blur(18px);
  }

  .nav-status span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 24px var(--lime);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, .9fr);
    gap: 34px;
    align-items: stretch;
  }

  .hero-copy, .mission-card, .timeline-section, .note-card {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.045));
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .hero-copy {
    padding: clamp(28px, 5vw, 56px);
    border-radius: var(--radius-card);
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .eyebrow, .section-heading p, .card-label {
    margin: 0 0 18px;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: .76rem;
    font-weight: 950;
  }

  h1 {
    margin: 0;
    max-width: 760px;
    font-size: clamp(4.5rem, 12vw, 9.4rem);
    line-height: .78;
    letter-spacing: -.1em;
  }

  h1 em {
    display: block;
    width: fit-content;
    font-style: normal;
    color: var(--lime);
    text-shadow: 5px 5px 0 rgba(255, 79, 216, .35), -4px -4px 0 rgba(102, 227, 255, .2);
    transform: rotate(-2deg);
  }

  .lede {
    max-width: 700px;
    margin: 28px 0 0;
    color: var(--subtle);
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    line-height: 1.6;
  }

  .lede a { color: var(--ink); text-decoration-color: var(--hot); text-decoration-thickness: 3px; text-underline-offset: 4px; }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .primary-cta, .ghost-cta, .calendar-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 20px;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 950;
