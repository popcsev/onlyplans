---
import PlanCard from '../components/PlanCard.astro';

const stops = [
  {
    time: '16:00',
    kicker: 'Stop 01',
    title: 'THE PARKING+ opens the portal',
    href: 'https://www.schallfenster.art/parking',
    text: 'Olaf arrives at Schallfenster’s secret Zürich location. Wristband acquired. Civilian identity begins to dissolve.',
    meta: 'Schallfenster · Zürich · secret location',
    badge: 'confirmed'
  },
  {
    time: '16:00–18:00',
    kicker: 'Set 01',
    title: 'GEM',
    text: 'Opening transmission. Soft launch into the bass dimension.',
    meta: 'Parking session',
    badge: 'warm-up'
  },
  {
    time: '18:00–20:00',
    kicker: 'Set 02',
    title: 'DJ Mashallah',
    text: 'Signal strength increases. Olaf is now best tracked by rhythm, not GPS.',
    meta: 'Parking session',
    badge: 'rising'
  },
  {
    time: '20:00–22:00',
    kicker: 'Set 03',
    title: 'Carla Durisch',
    text: 'Prime-time slot. “One more track” becomes a legally binding emotional contract.',
    meta: 'Crosstown Rebels',
    badge: 'peak'
  },
  {
    time: '23:00',
    kicker: 'Stop 02',
    title: 'Contrabbasso migration',
    text: 'Olaf leaves THE PARKING+ and continues to Contrabbasso for further low-frequency fieldwork.',
    meta: 'second destination',
    badge: 'next'
  },
  {
    time: 'late',
    kicker: 'Protocol',
    title: 'Scientifically unavailable',
    text: 'If discovered: offer water. If dancing: do not disturb. If philosophical: deploy fries.',
    meta: 'status unknown, vibes loud',
    badge: 'olaf mode'
  }
];

const stats = [
  ['02.05.26', 'Saturday file'],
  ['16:00', 'first signal'],
  ['23:00', 'bass migration'],
  ['∞', 'Olaf lore']
];

const weather = {
  location: 'Zürich',
  now: '7°C · clear',
  feels: 'feels like 6°C',
  wind: '7 km/h wind',
  humidity: '56% humidity',
  outlook: [
    ['15:00', '19°C', 'patchy rain nearby', '100% rain chance'],
    ['18:00', '17°C', 'patchy rain nearby', '100% rain chance'],
    ['21:00', '14°C', 'clear', 'dry window']
  ],
  advice: 'Bring a light layer and a tiny umbrella. Olaf may pretend he is weatherproof; data disagrees.'
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>onlyplans.lol — Olaf’s Saturday</title>
    <meta name="description" content="Olaf’s actual Saturday itinerary: THE PARKING+ by Schallfenster, then Contrabbasso." />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <div class="orb orb-one" aria-hidden="true"></div>
    <div class="orb orb-two" aria-hidden="true"></div>

    <a class="skip-link" href="#timeline">Skip to schedule</a>
    <main class="site-shell">
      <nav class="topbar" aria-label="Top navigation">
        <a class="brand" href="/" aria-label="onlyplans home">
          <span class="brand-mark">☃️</span>
          <span>onlyplans</span>
        </a>
        <div class="nav-status"><span></span> Olaf live-ish tracker</div>
      </nav>

      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="eyebrow">Zürich · Saturday · highly unofficial operations desk</p>
          <h1 id="page-title">Olaf has <em>plans</em>.</h1>
          <p class="lede">Tonight’s itinerary is no longer theoretical: first <a href="https://www.schallfenster.art/parking" target="_blank" rel="noopener">THE PARKING+ by Schallfenster</a>, then a dignified little bass pilgrimage to <strong>Contrabbasso</strong>.</p>

          <div class="cta-row">
            <a class="primary-cta" href="#timeline">View the route</a>
            <a class="ghost-cta" href="https://www.schallfenster.art/parking" target="_blank" rel="noopener">Schallfenster ↗</a>
          </div>

          <div class="stats" aria-label="Plan summary">
            {stats.map(([value, label]) => (
              <div class="stat"><strong>{value}</strong><span>{label}</span></div>
            ))}
          </div>
        </div>

        <aside class="mission-card" aria-label="Olaf mission card">
          <div class="card-label">CURRENT MISSION</div>
          <div class="route-map">
            <div class="route-node active"><span>01</span><strong>THE PARKING+</strong><small>Schallfenster</small></div>
            <div class="route-line"></div>
            <div class="route-node"><span>02</span><strong>Contrabbasso</strong><small>second act</small></div>
          </div>
          <div class="weather-widget" aria-label="Zürich weather snapshot">
            <div>
              <span class="weather-kicker">weather now · {weather.location}</span>
              <strong>{weather.now}</strong>
              <p>{weather.feels} · {weather.wind} · {weather.humidity}</p>
            </div>
            <div class="weather-icon" aria-hidden="true">🌦️</div>
          </div>
          <div class="olaf-chip">Status: beautifully over-scheduled</div>
        </aside>
      </section>

      <section class="timeline-section" id="timeline" aria-labelledby="timeline-title">
        <div class="section-heading">
          <p>Actual schedule</p>
          <h2 id="timeline-title">The Olaf Saturday run sheet</h2>
        </div>

        <div class="timeline">
          {stops.map((stop) => (
            <article class="timeline-card">
              <div class="time-block"><span>{stop.kicker}</span><strong>{stop.time}</strong></div>
              <div class="timeline-body">
                <h3>{stop.href ? <a href={stop.href} target="_blank" rel="noopener">{stop.title}</a> : stop.title}</h3>
                <p>{stop.text}</p>
                <small>{stop.meta}</small>
              </div>
              <div class="badge">{stop.badge}</div>
            </article>
          ))}
        </div>
      </section>

      <section class="weather-section" aria-labelledby="weather-title">
        <div class="section-heading compact">
          <p>Weather intelligence</p>
          <h2 id="weather-title">Can Olaf survive outside?</h2>
        </div>
        <div class="weather-panel">
          <div class="weather-main">
            <span>🌦️</span>
            <div>
              <strong>{weather.location}: {weather.now}</strong>
              <p>{weather.advice}</p>
            </div>
          </div>
          <div class="weather-slots">
            {weather.outlook.map(([time, temp, condition, rain]) => (
              <div class="weather-slot">
                <span>{time}</span>
                <strong>{temp}</strong>
                <p>{condition}</p>
                <small>{rain}</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="cards-grid" aria-label="Plan notes">
        <div class="note-card big">
          <span>🅿️</span>
          <h3>Parking first</h3>
          <p>Schallfenster’s 12-hour session is the launchpad: secret location, presale-only, wristband-powered.</p>
        </div>
        <div class="note-card">
          <span>🎻</span>
          <h3>Contrabbasso next</h3>
          <p>The second destination has class, bass, and suspiciously late-night timing.</p>
        </div>
        <div class="note-card">
          <span>🛰️</span>
          <h3>Tracking method</h3>
          <p>Approximate. Vibe-based. Legally distinct from surveillance.</p>
        </div>
      </section>

      <footer>
        <span>onlyplans.lol</span>
        <span>Built with Astro. Powered by Olaf’s inability to stay home.</span>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;

    /* Primitive + semantic tokens, per the web-design skill */
    --ink: #f8fafc;
    --muted: #a7b0c0;
    --subtle: rgba(248, 250, 252, .72);
    --surface-0: #070a12;
    --surface-1: rgba(12, 18, 32, .72);
    --surface-2: rgba(19, 27, 46, .9);
    --line: rgba(255, 255, 255, .13);
    --hot: #ff4fd8;
    --blue: #66e3ff;
    --lime: #d8ff6f;
    --amber: #ffb86b;

    --space-2: .5rem;
    --space-3: .75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;
    --space-16: 4rem;

    --radius-card: 2.25rem;
    --radius-panel: 1.75rem;
    --radius-pill: 999px;
    --shadow: 0 32px 90px rgba(0, 0, 0, .42);
    --shadow-soft: 0 18px 42px rgba(0, 0, 0, .28);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at 15% 12%, rgba(102, 227, 255, .28), transparent 30rem),
      radial-gradient(circle at 82% 6%, rgba(255, 79, 216, .26), transparent 28rem),
      radial-gradient(circle at 55% 100%, rgba(216, 255, 111, .14), transparent 34rem),
      linear-gradient(135deg, #070a12 0%, #101827 48%, #070a12 100%);
    overflow-x: hidden;
  }

  a { color: inherit; }

  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: .09;
    z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 260 260' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .orb {
    position: fixed;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(8px);
    z-index: 0;
  }

  .orb-one { width: 18rem; height: 18rem; left: -6rem; bottom: 10%; background: rgba(255, 184, 107, .18); }
  .orb-two { width: 24rem; height: 24rem; right: -8rem; bottom: -8rem; background: rgba(102, 227, 255, .16); }

  .site-shell {
    position: relative;
    z-index: 1;
    width: min(1160px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 44px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    font-weight: 950;
    letter-spacing: -.05em;
    font-size: clamp(1.25rem, 2vw, 1.7rem);
  }

  .brand-mark {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 255, 255, .08);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.18), 0 16px 42px rgba(0,0,0,.28);
    animation: float 4.5s ease-in-out infinite;
  }

  .nav-status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, .06);
    color: var(--subtle);
    font-weight: 800;
    font-size: .9rem;
    backdrop-filter: blur(18px);
  }

  .nav-status span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 24px var(--lime);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, .9fr);
    gap: 34px;
    align-items: stretch;
  }

  .hero-copy, .mission-card, .timeline-section, .note-card {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.045));
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .hero-copy {
    padding: clamp(28px, 5vw, 56px);
    border-radius: var(--radius-card);
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .eyebrow, .section-heading p, .card-label {
    margin: 0 0 18px;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: .76rem;
    font-weight: 950;
  }

  h1 {
    margin: 0;
    max-width: 760px;
    font-size: clamp(4.5rem, 12vw, 9.4rem);
    line-height: .78;
    letter-spacing: -.1em;
  }

  h1 em {
    display: block;
    width: fit-content;
    font-style: normal;
    color: var(--lime);
    text-shadow: 5px 5px 0 rgba(255, 79, 216, .35), -4px -4px 0 rgba(102, 227, 255, .2);
    transform: rotate(-2deg);
  }

  .lede {
    max-width: 700px;
    margin: 28px 0 0;
    color: var(--subtle);
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    line-height: 1.6;
  }

  .lede a { color: var(--ink); text-decoration-color: var(--hot); text-decoration-thickness: 3px; text-underline-offset: 4px; }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .primary-cta, .ghost-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 20px;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 950;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .primary-cta { color: #07101d; background: var(--lime); box-shadow: 0 18px 42px rgba(216,255,111,.2); }
  .ghost-cta { border: 1px solid var(--line); background: rgba(255,255,255,.06); color: var(--ink); }
  .primary-cta:hover, .ghost-cta:hover { transform: translateY(-3px); }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin-top: 34px;
  }

  .stat {
    padding: 16px;
    border-radius: 20px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.055);
  }

  .stat strong { display: block; font-size: 1.25rem; letter-spacing: -.04em; }
  .stat span { display: block; margin-top: 4px; color: var(--muted); font-weight: 800; font-size: .82rem; }

  .mission-card {
    position: relative;
    overflow: hidden;
    padding: 28px;
    border-radius: var(--radius-card);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 560px;
  }

  .mission-card::before {
    content: "";
    position: absolute;
    inset: 18px;
    border-radius: var(--radius-panel);
    border: 1px dashed rgba(255,255,255,.18);
    pointer-events: none;
  }

  .route-map {
    position: relative;
    display: grid;
    gap: 18px;
    margin: 60px 0;
  }

  .route-node {
    position: relative;
    z-index: 1;
    padding: 22px;
    border-radius: var(--radius-panel);
    border: 1px solid var(--line);
    background: var(--surface-2);
  }

  .route-node.active { background: linear-gradient(135deg, rgba(102,227,255,.22), rgba(255,79,216,.12)); }
  .route-node span { display: inline-grid; place-items: center; width: 34px; height: 34px; border-radius: 12px; background: var(--ink); color: #07101d; font-weight: 950; }
  .route-node strong { display: block; margin-top: 16px; font-size: clamp(1.5rem, 3vw, 2.15rem); letter-spacing: -.05em; }
  .route-node small { display: block; margin-top: 6px; color: var(--muted); font-weight: 850; }

  .route-line {
    width: 3px;
    height: 56px;
    margin-left: 38px;
    border-radius: 99px;
    background: linear-gradient(var(--blue), var(--hot));
    box-shadow: 0 0 24px rgba(102,227,255,.4);
  }

  .olaf-chip {
    width: fit-content;
    padding: 12px 14px;
    border-radius: 999px;
    background: rgba(216,255,111,.12);
    border: 1px solid rgba(216,255,111,.28);
    color: var(--lime);
    font-weight: 950;
  }

  .timeline-section {
    margin-top: 28px;
    padding: clamp(24px, 4vw, 42px);
    border-radius: var(--radius-card);
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 22px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 4.3rem);
    line-height: .9;
    letter-spacing: -.07em;
  }

  .timeline { display: grid; gap: 12px; }

  .timeline-card {
    display: grid;
    grid-template-columns: 148px 1fr auto;
    gap: 18px;
    align-items: center;
    padding: 18px;
    border-radius: 26px;
    border: 1px solid var(--line);
    background: rgba(4, 8, 16, .42);
    transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
  }

  .timeline-card:hover {
    transform: translateY(-2px);
    border-color: rgba(102,227,255,.38);
    background: rgba(255,255,255,.075);
  }

  .time-block span {
    display: block;
    color: var(--hot);
    text-transform: uppercase;
    letter-spacing: .13em;
    font-size: .68rem;
    font-weight: 950;
  }

  .time-block strong {
    display: block;
    margin-top: 6px;
    font-size: 1.35rem;
    letter-spacing: -.04em;
  }

  .timeline-body h3 { margin: 0 0 6px; font-size: clamp(1.15rem, 2vw, 1.55rem); letter-spacing: -.035em; }
  .timeline-body h3 a { text-decoration: none; }
  .timeline-body h3 a:hover { color: var(--blue); }
  .timeline-body p { margin: 0; max-width: 72ch; color: var(--subtle); line-height: 1.55; }
  .timeline-body small { display: block; margin-top: 8px; color: var(--muted); font-weight: 850; }

  .badge {
    padding: 9px 11px;
    border-radius: 999px;
    background: rgba(102,227,255,.11);
    border: 1px solid rgba(102,227,255,.22);
    color: var(--blue);
    font-size: .78rem;
    font-weight: 950;
    white-space: nowrap;
  }


  .weather-section {
    margin-top: 28px;
    padding: clamp(24px, 4vw, 42px);
    border-radius: var(--radius-card);
    border: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(102,227,255,.12), rgba(216,255,111,.08));
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(24px);
  }

  .section-heading.compact { margin-bottom: 18px; }
  .section-heading.compact h2 { font-size: clamp(1.8rem, 4vw, 3.2rem); }

  .weather-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, .9fr);
    gap: var(--space-4);
    align-items: stretch;
  }

  .weather-main, .weather-widget, .weather-slot {
    border: 1px solid var(--line);
    background: rgba(4, 8, 16, .42);
  }

  .weather-main {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: clamp(18px, 3vw, 28px);
    border-radius: var(--radius-panel);
  }

  .weather-main > span { font-size: clamp(2.4rem, 6vw, 4.5rem); }
  .weather-main strong { display: block; font-size: clamp(1.35rem, 3vw, 2.2rem); letter-spacing: -.05em; }
  .weather-main p { max-width: 58ch; margin: 8px 0 0; color: var(--subtle); line-height: 1.55; }

  .weather-slots {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .weather-slot {
    padding: 16px;
    border-radius: 22px;
  }

  .weather-slot span, .weather-kicker {
    display: block;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: .13em;
    font-size: .68rem;
    font-weight: 950;
  }

  .weather-slot strong { display: block; margin-top: 10px; font-size: 1.45rem; }
  .weather-slot p { margin: 6px 0 0; color: var(--subtle); line-height: 1.35; }
  .weather-slot small { display: block; margin-top: 10px; color: var(--amber); font-weight: 900; }

  .weather-widget {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 16px;
    border-radius: 24px;
  }

  .weather-widget strong { display: block; margin-top: 6px; font-size: 1.25rem; letter-spacing: -.04em; }
  .weather-widget p { margin: 4px 0 0; color: var(--muted); font-weight: 800; font-size: .86rem; line-height: 1.35; }
  .weather-icon { font-size: 2rem; }


  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 14px;
    margin-top: 28px;
  }

  .note-card {
    padding: 24px;
    border-radius: var(--radius-panel);
  }

  .note-card.big { background: linear-gradient(135deg, rgba(255,79,216,.18), rgba(102,227,255,.08)); }
  .note-card span { font-size: 2rem; }
  .note-card h3 { margin: 14px 0 8px; font-size: 1.35rem; letter-spacing: -.04em; }
  .note-card p { margin: 0; color: var(--subtle); line-height: 1.5; }

  footer {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 30px;
    color: var(--muted);
    font-weight: 850;
    font-size: .92rem;
  }

  footer span:first-child { color: var(--ink); }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-6px) rotate(5deg); }
  }


  .skip-link {
    position: fixed;
    left: 16px;
    top: 16px;
    z-index: 10;
    translate: 0 -140%;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-pill);
    background: var(--lime);
    color: #07101d;
    font-weight: 950;
    text-decoration: none;
    box-shadow: var(--shadow-soft);
    transition: translate 160ms ease-out;
  }

  .skip-link:focus-visible { translate: 0; }

  :focus-visible {
    outline: 3px solid var(--lime);
    outline-offset: 4px;
    border-radius: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }


